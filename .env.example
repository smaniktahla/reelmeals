# Copy this to .env and fill in your values
# cp .env.example .env

# Whisper model size: tiny, base, small, medium
# 'small' is the sweet spot for accuracy vs speed on CPU
WHISPER_MODEL=small

# Tandoor instance URL and API token
# Get your token from Tandoor: Settings → API Tokens
TANDOOR_URL=http://your-tandoor-host:8080
TANDOOR_TOKEN=your_tandoor_token_here

# Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
