# ═══════════════════════════════════════════════════════════════════
# ReelMeals v4 — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Only infrastructure settings live here.
# API keys, Tandoor/Mealie config, and cookies are now per-user
# and managed in the web UI Settings page.
# ═══════════════════════════════════════════════════════════════════

# ── Whisper (speech-to-text) ──────────────────────────────────────
WHISPER_MODEL=small        # tiny | base | small | medium
WHISPER_DEVICE=cpu         # cpu | cuda

# ── Session Security ─────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# ── Authentication ───────────────────────────────────────────────
AUTH_LOCAL=true             # Enable username/password login
AUTH_OIDC=false             # Enable OIDC (Authentik, Keycloak, etc.)
ALLOW_REGISTRATION=true    # Allow new users to self-register

# ── OIDC Config (only if AUTH_OIDC=true) ─────────────────────────
# OIDC_ISSUER=https://auth.lightbulbfan.duckdns.org/application/o/reelmeals
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://10.10.10.13:8091/api/auth/oidc/callback
# OIDC_PROVIDER_NAME=Authentik
# OIDC_SCOPES=openid profile email
